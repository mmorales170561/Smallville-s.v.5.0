#!/bin/bash

# --- THE SMALLVILLE MISSION SUITE: RESTORED ---
# Aesthetics and sequence restored to original specifications

# UI Elements
divider="======================================================"

# 1. ACTION COMICS AUTHENTICATION
clear
echo -e "\e[1;31m$divider\e[0m"
echo -e "   [!] SECURE LINK: ACTION COMICS AUTHENTICATION"
echo -e "$divider\e[0m"
echo -n "   Enter Secret Key: "
read -s access < /dev/tty
if [[ "$access" != "krypton" ]]; then
    echo -e "\n\e[1;31m   [!] ACCESS DENIED: IDENTITY NOT VERIFIED.\e[0m"
    exit 1
fi

# 2. SMALLVILLE NODE HANDSHAKE
echo -e "\n\e[1;32m   [+] Identity Verified."
echo -e "\e[1;34m   [!] Establishing Secure Handshake with Smallville Node...\e[0m"
sleep 1.5
echo -e "   [+] Smallville Connection: SECURED."

# 3. FORTRESS GATEKEEPER
echo -e "\n\e[1;36m   [!] Gatekeeper: Validating Mission Protocols...\e[0m"
for tool in subfinder httpx; do
    if ! command -v $tool &> /dev/null; then
        echo -e "\e[1;31m   [!] Gatekeeper Alert: Critical tool $tool is missing.\e[0m"
        exit 1
    fi
done
echo -e "\e[1;32m   [!] Gatekeeper: All systems green.\e[0m"

# 4. DAILY PLANET: MISSION RECON
echo -e "\n"
figlet -f slant "DAILY PLANET"
echo -e "\e[1;33m$divider"
echo -e "   [?] MISSION BRIEFING: INPUT PARAMETERS"
echo -e "$divider\e[0m"
echo -n "   Target Domain: "; target=$(head -n 1 < /dev/tty)
echo -n "   In-Scope Regex: "; inscope=$(head -n 1 < /dev/tty)
echo -n "   Out-of-Scope Regex: "; outscope=$(head -n 1 < /dev/tty)
# --- INTELLIGENT HUNT ---
    echo -e "\e[1;36m[!] Scanning Target: $target\e[0m"
    
    # Run subfinder, but don't fail if it returns nothing
    $HOME/go/bin/subfinder -d "$target" -silent > results.tmp
    
    # FALLBACK: If results.tmp is empty, add the target domain manually
    if [ ! -s results.tmp ]; then
        echo "$target" > results.tmp
    fi
    
    # Now proceed with filtering
    cat results.tmp | grep -E "$inscope" | grep -vE "$outscope" > filtered.tmp

# 5. MISSION EXECUTION
echo -e "\n\e[1;34m   --- LAUNCHING RECON SEQUENCE ---\e[0m"
subfinder -d "$target" -silent | grep -E "$inscope" | grep -vE "$outscope" > .found.txt
httpx -l .found.txt -silent -o .results.txt
echo -e "\e[1;36m   [!] Mission Report:\e[0m"
cat .results.txt
rm .found.txt .results.txt
echo -e "\n\e[1;32m   [!] Mission Accomplished. Daily Planet Logs Updated.\e[0m"
